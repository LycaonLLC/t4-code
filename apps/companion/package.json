    "vite-plus": "catalog:"
  },
  "scripts": {
    "doctor": "node scripts/doctor.mjs",
    "doctor:ios": "node scripts/doctor.mjs --platform ios",
    "doctor:android": "node scripts/doctor.mjs --platform android",
